{
  "schemaVersion": 1,
  "name": "Kuviewer Desktop Cluster Explorer",
  "goal": "installable-read-only-desktop-cluster-explorer",
  "status": "desktop-signing-notarization",
  "recommendedPackager": "tauri",
  "fallbackPackager": "electron",
  "tauri": {
    "packagePath": "desktop/package.json",
    "configPath": "desktop/src-tauri/tauri.conf.json",
    "cargoManifestPath": "desktop/src-tauri/Cargo.toml",
    "capabilityPath": "desktop/src-tauri/capabilities/desktop-readonly.json",
    "frontendDist": "../../website/dist",
    "devUrl": "http://127.0.0.1:5174/kuviewer/"
  },
  "targets": [
    {
      "platform": "macos",
      "artifact": "dmg"
    },
    {
      "platform": "windows",
      "artifact": "exe"
    }
  ],
  "connectionModes": [
    {
      "id": "remote-api",
      "description": "Connect the desktop shell to an existing Kuviewer server URL with the same admin-token flow as the web app."
    },
    {
      "id": "local-sidecar",
      "description": "Future option: run the Go read-only API server as a local sidecar and point the desktop shell at localhost."
    }
  ],
  "remoteConnectionProfile": {
    "status": "scaffolded",
    "runtimeOnly": true,
    "storage": "localStorage-url-only",
    "storageKey": "kuviewer_desktop_connection_profile",
    "allowedProtocols": ["https", "http"],
    "httpLoopbackOnly": true,
    "adminTokenStorage": "sessionStorage",
    "clearsAdminTokenOnChange": true,
    "noKubeconfigPersistence": true,
    "noSecretValues": true,
    "requiresServerCors": true
  },
  "releaseVersioning": {
    "status": "scaffolded",
    "versionScript": "scripts/set-desktop-package-version.mjs",
    "sourceFiles": [
      "desktop/package.json",
      "desktop/src-tauri/Cargo.toml",
      "desktop/src-tauri/tauri.conf.json"
    ],
    "workflowInput": "package_version",
    "tagPrefix": "v",
    "fallbackVersion": "0.1.0",
    "artifactNamePattern": "kuviewer-{platform}-{artifact}-{version}",
    "ciWorkspaceOnly": true,
    "noCredentialPersistence": true
  },
  "buildPrerequisites": [
    {
      "id": "node",
      "requiredFor": ["macos", "windows"],
      "purpose": "Run the existing Vite frontend build before Tauri bundles the app."
    },
    {
      "id": "npm",
      "requiredFor": ["macos", "windows"],
      "purpose": "Install website and desktop package dependencies."
    },
    {
      "id": "rust",
      "requiredFor": ["macos", "windows"],
      "purpose": "Compile the Tauri shell."
    },
    {
      "id": "cargo",
      "requiredFor": ["macos", "windows"],
      "purpose": "Run the Rust build and package commands used by Tauri."
    },
    {
      "id": "xcode-command-line-tools",
      "requiredFor": ["macos"],
      "purpose": "Provide the macOS linker and native build tools for .dmg generation."
    },
    {
      "id": "windows-runner",
      "requiredFor": ["windows"],
      "purpose": "Build the Windows NSIS .exe on a Windows host or CI runner."
    }
  ],
  "icons": {
    "generationScript": "scripts/generate-desktop-icons.mjs",
    "sourceAssets": [
      {
        "id": "yaml-flow-source",
        "path": "website/public/images/brand/kuviewer-icon-yaml-flow.png",
        "size": "512x512",
        "transparent": true
      },
      {
        "id": "favicon-32",
        "path": "website/public/favicon-32x32.png",
        "size": "32x32",
        "transparent": true
      },
      {
        "id": "favicon-192",
        "path": "website/public/favicon-192x192.png",
        "size": "192x192",
        "transparent": true
      },
      {
        "id": "apple-touch-icon",
        "path": "website/public/apple-touch-icon.png",
        "size": "180x180",
        "transparent": true
      }
    ],
    "generatedAssets": [
      {
        "path": "desktop/src-tauri/icons/32x32.png",
        "size": "32x32",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128.png",
        "size": "128x128",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128@2x.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.icns",
        "format": "icns",
        "platform": "macos"
      },
      {
        "path": "desktop/src-tauri/icons/icon.ico",
        "format": "ico",
        "platform": "windows"
      }
    ],
    "noCroppedCandidateImages": true
  },
  "signing": {
    "status": "ci-enabled",
    "noCertificatesInRepo": true,
    "noPrivateKeysInRepo": true,
    "workflowPath": ".github/workflows/desktop-package.yml",
    "signingConfigScript": "scripts/configure-desktop-signing.mjs",
    "manualOnly": true,
    "unsignedBuildDefault": true,
    "signedBuildRequiresSecrets": true,
    "macos": "Import an Apple Developer ID .p12 from CI secrets into a temporary GitHub runner keychain, sign with the configured identity, and pass Apple notarization credentials through CI secrets only.",
    "macosMode": "temporary-keychain-p12",
    "macosNotarizationMode": "apple-id-env",
    "macosSecretNames": [
      "APPLE_CERTIFICATE_BASE64",
      "APPLE_CERTIFICATE_PASSWORD",
      "APPLE_SIGNING_IDENTITY",
      "APPLE_ID",
      "APPLE_PASSWORD",
      "APPLE_TEAM_ID"
    ],
    "windows": "Import a Windows PFX from CI secrets into the CurrentUser certificate store, inject the certificate thumbprint into the CI workspace Tauri config, and remove the certificate after packaging.",
    "windowsMode": "current-user-pfx-thumbprint",
    "windowsTimestampUrlDefault": "http://timestamp.digicert.com",
    "windowsSecretNames": [
      "WINDOWS_CERTIFICATE_BASE64",
      "WINDOWS_CERTIFICATE_PASSWORD"
    ]
  },
  "dryRuns": [
    {
      "id": "macos-dmg-unsigned-2026-06-19",
      "platform": "macos",
      "artifact": "dmg",
      "signed": false,
      "workflow": "desktop-package",
      "workflowRunId": 27800527207,
      "workflowRunUrl": "https://github.com/pxzhu/kuviewer/actions/runs/27800527207",
      "ref": "main",
      "commit": "d525971d7415a6053eb8f45d92f5a3573654e3cd",
      "conclusion": "success",
      "startedAt": "2026-06-19T01:52:03Z",
      "completedAt": "2026-06-19T01:55:20Z",
      "outputFile": "Kuviewer_0.1.0_aarch64.dmg",
      "artifactName": "kuviewer-macos-dmg",
      "artifactId": 7740045761,
      "artifactSizeBytes": 7125256,
      "artifactZipSha256": "3a663ab3e3cba2bd12e14cf692cf699f5ee862f15f4cb80d4840ff98dad173ec"
    },
    {
      "id": "windows-exe-unsigned-2026-06-19",
      "platform": "windows",
      "artifact": "exe",
      "signed": false,
      "workflow": "desktop-package",
      "workflowRunId": 27803179419,
      "workflowRunUrl": "https://github.com/pxzhu/kuviewer/actions/runs/27803179419",
      "ref": "main",
      "commit": "b754c549ee2a2766c7f2d32257e4ee66a426aeb2",
      "conclusion": "success",
      "startedAt": "2026-06-19T03:16:45Z",
      "completedAt": "2026-06-19T03:23:53Z",
      "outputFile": "Kuviewer_0.1.0_x64-setup.exe",
      "artifactName": "kuviewer-windows-exe",
      "artifactId": 7741029893,
      "artifactSizeBytes": 5777828,
      "artifactZipSha256": "904285edb5307f1426f386ef340d413c81623e41ad57a835f0ea303c778970c4"
    }
  ],
  "security": {
    "readOnly": true,
    "noBrowserKubeCredentialEntry": true,
    "noSecretValues": true,
    "noKubeconfigPersistence": true,
    "noAdminTokenPersistence": true,
    "noOperationalActions": [
      "exec",
      "port-forward",
      "restart",
      "scale",
      "delete",
      "apply",
      "edit"
    ]
  },
  "phaseOrder": [
    "packaging-spec",
    "tauri-scaffold",
    "remote-connection-profile",
    "release-versioning",
    "local-sidecar-evaluation",
    "macos-dmg-build",
    "windows-exe-build",
    "signing-and-release"
  ]
}
