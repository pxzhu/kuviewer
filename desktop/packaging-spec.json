{
  "schemaVersion": 1,
  "goal": "desktop-cm-session-prototype",
  "status": "prototype-only",
  "product": {
    "primaryPath": "web-server",
    "desktopInstallerPublished": false,
    "desktopDownloadWorkflow": false,
    "webExposesSsh": false
  },
  "runtime": {
    "framework": "tauri",
    "desktopOnly": true,
    "localSidecarIncluded": false,
    "directKubernetesProfileIncluded": false
  },
  "connectionModes": [
    "cm-ssh-session"
  ],
  "security": {
    "readOnly": true,
    "privateKeyStorage": "os-credential-store",
    "adminTokenStorage": "sessionStorage",
    "noSecretValues": true,
    "noKubeconfigPersistence": true,
    "noRawSshStderr": true,
    "noOperationalActions": [
      "exec",
      "port-forward",
      "restart",
      "scale",
      "delete",
      "apply",
      "edit"
    ]
  },
  "safePreferenceStorage": [
    "kuviewer_desktop_cm_diagnostic_filter_presets",
    "kuviewer_desktop_cm_session_view_preferences",
    "kuviewer_desktop_cm_session_layout_presets",
    "kuviewer_desktop_cm_session_layout_collapsed_folders"
  ],
  "exportPolicy": {
    "safeSessionFields": [
      "name",
      "host",
      "port",
      "user",
      "remoteApiHost",
      "remoteApiPort",
      "description"
    ],
    "forbiddenFields": [
      "privateKey",
      "credential",
      "adminToken",
      "kubeconfig",
      "cloudCredential",
      "secretValue",
      "rawSshStderr",
      "events",
      "logs"
    ]
  },
  "requiredFiles": [
    "desktop/src-tauri/Cargo.lock",
    "desktop/src-tauri/Cargo.toml",
    "desktop/src-tauri/tauri.conf.json",
    "desktop/src-tauri/src/main.rs",
    "website/src/components/DesktopCmSessionPanel.tsx",
    "website/src/components/desktopCm/DesktopCmSessionList.tsx",
    "website/src/features/desktop/desktopCmSessionView.ts"
  ],
  "next": [
    "split remaining desktop session and saved-layout JSX into local-prototype modules",
    "archive the desktop prototype if real CM workflows do not use it"
  ]
}
