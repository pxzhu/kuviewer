{
  "schemaVersion": 1,
  "name": "Kuviewer Desktop CM Session Explorer",
  "goal": "desktop-cm-session-prototype",
  "status": "desktop-cm-session-clone-polish",
  "recommendedPackager": "tauri",
  "fallbackPackager": "electron",
  "tauri": {
    "packagePath": "desktop/package.json",
    "configPath": "desktop/src-tauri/tauri.conf.json",
    "cargoManifestPath": "desktop/src-tauri/Cargo.toml",
    "capabilityPath": "desktop/src-tauri/capabilities/desktop-readonly.json",
    "frontendDist": "../../website/dist",
    "devUrl": "http://127.0.0.1:5174/kuviewer/"
  },
  "distributionPolicy": {
    "status": "download-installer-descope",
    "installerDownloads": false,
    "releaseAssetPublishing": false,
    "desktopPackageWorkflow": false,
    "signedInstallerRelease": false,
    "notes": "Desktop code remains a local CM/SSH session prototype. Public downloadable installer artifacts are not part of the active Kuviewer product path."
  },
  "connectionModes": [
    {
      "id": "cm-ssh-session",
      "description": "Future desktop-local prototype direction: manage multiple desktop-only sessions to CM or bastion servers over an SSH-style connection model."
    },
    {
      "id": "remote-api",
      "description": "Prototype compatibility path only; not the primary desktop product direction."
    },
    {
      "id": "local-sidecar",
      "description": "Historical packaging/runtime scaffold for evaluation only; not the primary desktop product direction."
    },
    {
      "id": "local-kubernetes-keychain",
      "description": "Credential-store prototype path superseded by the CM/SSH session manager direction for product work."
    }
  ],
  "desktopProductDirection": {
    "primaryConnectionMode": "cm-ssh-session",
    "desktopOnly": true,
    "webSshFeature": false,
    "multipleSessions": true,
    "sessionModel": "vscode-ssh-extension-style",
    "localSidecarPolicy": "prototype-only-not-product-default",
    "directApiPolicy": "not-desktop-primary",
    "credentialStorage": "os-credential-store",
    "noBrowserSsh": true,
    "noOperationalActions": true
  },
  "cmSshSessionManager": {
    "status": "session-clone-polish",
    "desktopOnly": true,
    "webExposed": false,
    "storage": "tauri-state-safe-metadata-with-os-credential-store-and-session-runtime",
    "secretStorage": "os-credential-store-private-key",
    "defaultPort": 22,
    "actualSshConnection": true,
    "safeMetadataFields": [
      "id",
      "name",
      "host",
      "port",
      "user",
      "remoteApiHost",
      "remoteApiPort",
      "authType",
      "credentialStore",
      "credentialAvailable",
      "status",
      "runtimeStatus",
      "updatedAt",
      "selected",
      "description",
      "lastCheckStatus",
      "lastCheckAt",
      "lastCheckMessage",
      "diagnosticStage",
      "diagnosticSeverity",
      "diagnosticMessage",
      "diagnosticHint"
    ],
    "commands": [
      "desktop_cm_sessions",
      "desktop_save_cm_session",
      "desktop_select_cm_session",
      "desktop_delete_cm_session",
      "desktop_import_cm_session_private_key",
      "desktop_delete_cm_session_credential",
      "desktop_check_cm_session",
      "desktop_cm_session_runtime",
      "desktop_start_cm_session_runtime",
      "desktop_stop_cm_session_runtime",
      "desktop_check_cm_session_runtime"
    ],
    "runtimeSafeProfileFields": [
      "sessionId",
      "sessionName",
      "serverUrl",
      "remoteApiHost",
      "remoteApiPort",
      "localPort",
      "status",
      "startedAt",
      "healthStatus",
      "lastHealthAt",
      "lastHealthMessage",
      "lastError",
      "diagnosticStage",
      "diagnosticSeverity",
      "diagnosticMessage",
      "diagnosticHint"
    ],
    "diagnosticPolicy": {
      "stages": ["metadata", "credential", "reachability", "ssh-auth", "tunnel", "health", "runtime"],
      "severities": ["info", "warning", "error"],
      "safeOnly": true,
      "noRawStderr": true,
      "noPrivateKeyBody": true,
      "noToken": true,
      "noKubeconfig": true,
      "noSecretValues": true,
      "noCloudCredentials": true
    },
    "exportImportPolicy": {
      "desktopOnly": true,
      "schemaVersion": 1,
      "kind": "kuviewer.desktop.cmSessions",
      "maxImportItems": 50,
      "safeEditableFieldsOnly": true,
      "fields": ["name", "host", "port", "user", "remoteApiHost", "remoteApiPort", "description"],
      "noPrivateKeyBody": true,
      "noCredentialPayload": true,
      "noRuntimeProfile": true,
      "noDiagnosticHistory": true,
      "noToken": true,
      "noKubeconfig": true,
      "noSecretValues": true,
      "noEventsOrLogs": true
    },
    "diagnosticFiltering": {
      "desktopOnly": true,
      "uiOnly": true,
      "persisted": false,
      "exported": false,
      "usesDisplayedDiagnosticSource": true,
      "fields": ["diagnosticStage", "diagnosticSeverity"]
    },
    "diagnosticSavedFilters": {
      "desktopOnly": true,
      "storage": "localStorage-ui-preference",
      "storageKey": "kuviewer_desktop_cm_diagnostic_filter_presets",
      "maxPresets": 8,
      "maxNameLength": 40,
      "fields": ["name", "diagnosticStage", "diagnosticSeverity", "updatedAt"],
      "noSessionSearch": true,
      "noSessionData": true,
      "noCredentialPayload": true,
      "noRuntimeProfile": true,
      "noDiagnosticHistory": true,
      "noExportImportPayload": true
    },
    "connectionProfilePolish": {
      "desktopOnly": true,
      "uiOnly": true,
      "noNewStorage": true,
      "noExportImportSchemaChange": true,
      "noCredentialPayload": true,
      "noRuntimeProfile": true,
      "quickApiPresets": [
        { "host": "127.0.0.1", "port": 18085 },
        { "host": "localhost", "port": 18085 },
        { "host": "127.0.0.1", "port": 8080 }
      ],
      "frontendValidation": ["name", "host", "user", "port", "remoteApiPort"]
    },
    "sessionClonePolish": {
      "desktopOnly": true,
      "uiOnly": true,
      "requiresExplicitSave": true,
      "noNewStorage": true,
      "noExportImportSchemaChange": true,
      "nameConflictPolicy": "append-copy-suffix",
      "fields": ["name", "host", "port", "user", "remoteApiHost", "remoteApiPort", "description"],
      "clearsId": true,
      "noCredentialPayload": true,
      "noCredentialAvailabilityCopy": true,
      "noRuntimeProfile": true,
      "noDiagnosticHistory": true,
      "noToken": true,
      "noKubeconfig": true,
      "noSecretValues": true
    },
    "hiddenPrototypeUi": [
      "DesktopConnectionProfilePanel",
      "DesktopKubernetesProfilePanel",
      "desktop-use-sidecar-profile"
    ],
    "next": [
      "desktop deploy SSH preflight hardening"
    ]
  },
  "remoteConnectionProfile": {
    "status": "prototype-only",
    "runtimeOnly": true,
    "storage": "localStorage-url-only",
    "storageKey": "kuviewer_desktop_connection_profile",
    "allowedProtocols": ["https", "http"],
    "httpLoopbackOnly": true,
    "adminTokenStorage": "sessionStorage",
    "clearsAdminTokenOnChange": true,
    "noKubeconfigPersistence": true,
    "noSecretValues": true,
    "requiresServerCors": true
  },
  "localSidecar": {
    "status": "runtime-scaffolded",
    "enabledInTauriConfig": true,
    "externalBinEnabled": true,
    "runtimeLaunch": "rust-managed",
    "javascriptShellPermission": false,
    "capabilityChangeDeferred": false,
    "requiresShellPluginLater": false,
    "buildBeforeTauri": true,
    "buildScript": "scripts/build-desktop-sidecar.mjs",
    "sourcePackage": "server/cmd/kuviewer-server",
    "outputDir": "desktop/src-tauri/binaries",
    "binaryBaseName": "kuviewer-sidecar",
    "tauriExternalBinCandidate": "binaries/kuviewer-sidecar",
    "gitIgnoredOutput": true,
    "targets": [
      {
        "targetTriple": "aarch64-apple-darwin",
        "goos": "darwin",
        "goarch": "arm64"
      },
      {
        "targetTriple": "x86_64-apple-darwin",
        "goos": "darwin",
        "goarch": "amd64"
      },
      {
        "targetTriple": "x86_64-pc-windows-msvc",
        "goos": "windows",
        "goarch": "amd64"
      },
      {
        "targetTriple": "aarch64-pc-windows-msvc",
        "goos": "windows",
        "goarch": "arm64"
      }
    ],
    "runtime": {
      "launchMode": "rust-managed-sidecar",
      "listenAddr": "127.0.0.1:18086",
      "adminToken": "generated-per-launch-memory-only",
      "adminTokenHandoff": "tauri-command-session-storage",
      "serverSource": "mock-default-env-overridable",
      "sourceEnv": "KUVIEWER_DESKTOP_SIDECAR_SOURCE",
      "disableEnv": "KUVIEWER_DESKTOP_DISABLE_SIDECAR",
      "staticDir": "disabled-for-sidecar-api",
      "resourceViewsStore": "runtime-memory-unless-user-configured-later"
    },
    "profileUx": {
      "status": "prototype-hidden",
      "displaysSidecarSource": true,
      "explicitUseSidecarButton": false,
      "remoteProfileCanOverrideLocal": true,
      "tokenRequeryOnSwitch": true,
      "noTokenPropDrilling": true
    },
    "security": {
      "loopbackOnly": true,
      "noBrowserKubeCredentialEntry": true,
      "noKubeconfigPersistence": true,
      "noAdminTokenPersistence": true,
      "noSecretValues": true,
      "noOperationalActions": true,
      "noCommittedBinaries": true,
      "noJavascriptShellPermission": true
    }
  },
  "credentialStorageDesign": {
    "status": "prototype-hidden-after-cm-session-manager",
    "documentPath": "desktop/KEYCHAIN_CREDENTIAL_DESIGN.md",
    "firstRuntimeScope": "bearer-token-only",
    "browserCredentialEntry": false,
    "browserCredentialPersistence": false,
    "frontendMetadataOnly": true,
    "safeMetadataStorage": "localStorage-profile-id-display-only",
    "osCredentialStores": ["macos-keychain", "windows-credential-manager"],
    "secretProfileMaterial": ["bearer-token", "ca-bundle"],
    "tokenTransport": "KUVIEWER_KUBE_TOKEN_FILE",
    "avoidBearerTokenEnvForDesktop": true,
    "tempFilePolicy": "0600-runtime-delete-on-exit",
    "noKubeconfigPersistence": true,
    "noSecretValues": true,
    "noOperationalActions": true,
    "runtimePrototype": {
      "metadataCommand": "desktop_kubernetes_profiles",
      "selectCommand": "desktop_select_kubernetes_profile",
      "deleteCredentialCommand": "desktop_delete_kubernetes_profile_credential",
      "uiPanel": "prototype-hidden",
      "secretReadWriteImplemented": true,
      "sidecarRestartImplemented": true,
      "browserReceivesSecrets": false,
      "credentialAvailableField": "credentialAvailable",
      "activeProfileStatus": "sidecar-kubernetes-active",
      "importTokenFileEnv": "KUVIEWER_DESKTOP_KUBE_TOKEN_FILE",
      "importTokenFileFlagEnv": "KUVIEWER_DESKTOP_KUBE_IMPORT_TOKEN_FILE",
      "runtimeTokenFileEnv": "KUVIEWER_KUBE_TOKEN_FILE",
      "runtimeTokenFilePolicy": "0600-temp-dir-delete-on-sidecar-stop",
      "runtimeSmoke": {
        "status": "prototype-hidden",
        "script": "scripts/smoke-desktop-keychain-runtime.mjs",
        "ciWorkflow": ".github/workflows/ci.yml",
        "requiresRealCredentialStore": false,
        "verifiedFlows": [
          "select-profile-restarts-sidecar-live",
          "delete-active-credential-clears-live-token"
        ]
      },
      "envMetadataFixture": [
        "KUVIEWER_DESKTOP_KUBE_API_SERVER",
        "KUVIEWER_DESKTOP_KUBE_PROFILE_ID",
        "KUVIEWER_DESKTOP_KUBE_PROFILE_NAME"
      ]
    }
  },
  "buildPrerequisites": [
    {
      "id": "node",
      "requiredFor": ["desktop-shell"],
      "purpose": "Run the existing Vite frontend build before Tauri bundles the app."
    },
    {
      "id": "npm",
      "requiredFor": ["desktop-shell"],
      "purpose": "Install website and desktop package dependencies."
    },
    {
      "id": "go",
      "requiredFor": ["desktop-shell"],
      "purpose": "Build the bundled Kuviewer Go API sidecar before Tauri packaging."
    },
    {
      "id": "rust",
      "requiredFor": ["desktop-shell"],
      "purpose": "Compile the Tauri shell."
    },
    {
      "id": "cargo",
      "requiredFor": ["desktop-shell"],
      "purpose": "Run the Rust build and package commands used by Tauri."
    }
  ],
  "icons": {
    "generationScript": "scripts/generate-desktop-icons.mjs",
    "sourceAssets": [
      {
        "id": "yaml-flow-source",
        "path": "website/public/images/brand/kuviewer-icon-yaml-flow.png",
        "size": "512x512",
        "transparent": true
      },
      {
        "id": "favicon-32",
        "path": "website/public/favicon-32x32.png",
        "size": "32x32",
        "transparent": true
      },
      {
        "id": "favicon-192",
        "path": "website/public/favicon-192x192.png",
        "size": "192x192",
        "transparent": true
      },
      {
        "id": "apple-touch-icon",
        "path": "website/public/apple-touch-icon.png",
        "size": "180x180",
        "transparent": true
      }
    ],
    "generatedAssets": [
      {
        "path": "desktop/src-tauri/icons/32x32.png",
        "size": "32x32",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128.png",
        "size": "128x128",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128@2x.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.icns",
        "format": "icns",
        "platform": "macos"
      },
      {
        "path": "desktop/src-tauri/icons/icon.ico",
        "format": "ico",
        "platform": "windows"
      }
    ],
    "noCroppedCandidateImages": true
  },
  "security": {
    "readOnly": true,
    "noBrowserKubeCredentialEntry": true,
    "noSecretValues": true,
    "noKubeconfigPersistence": true,
    "noAdminTokenPersistence": true,
    "noOperationalActions": [
      "exec",
      "port-forward",
      "restart",
      "scale",
      "delete",
      "apply",
      "edit"
    ]
  },
  "phaseOrder": [
    "packaging-spec",
    "tauri-scaffold",
    "remote-connection-profile",
    "local-sidecar-evaluation",
    "local-sidecar-runtime",
    "keychain-credential-design",
    "keychain-profile-runtime",
    "os-credential-store",
    "keychain-sidecar-runtime",
    "native-credential-runtime-smoke",
    "desktop-cm-ssh-sessions",
    "desktop-cm-ssh-credential-check",
    "desktop-cm-ssh-runtime",
    "desktop-cm-runtime-health-details",
    "desktop-download-descope",
    "desktop-cm-advanced-diagnostics",
    "desktop-cm-session-export-import",
    "desktop-cm-diagnostics-filtering",
    "desktop-cm-diagnostics-saved-filters",
    "desktop-cm-connection-profile-polish",
    "desktop-cm-session-clone-polish"
  ]
}
