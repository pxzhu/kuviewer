{
  "schemaVersion": 1,
  "name": "Kuviewer Desktop Cluster Explorer",
  "goal": "installable-read-only-desktop-cluster-explorer",
  "status": "tauri-scaffold",
  "recommendedPackager": "tauri",
  "fallbackPackager": "electron",
  "tauri": {
    "packagePath": "desktop/package.json",
    "configPath": "desktop/src-tauri/tauri.conf.json",
    "cargoManifestPath": "desktop/src-tauri/Cargo.toml",
    "capabilityPath": "desktop/src-tauri/capabilities/desktop-readonly.json",
    "frontendDist": "../../website/dist",
    "devUrl": "http://127.0.0.1:5174/kuviewer/"
  },
  "targets": [
    {
      "platform": "macos",
      "artifact": "dmg"
    },
    {
      "platform": "windows",
      "artifact": "exe"
    }
  ],
  "connectionModes": [
    {
      "id": "remote-api",
      "description": "Connect the desktop shell to an existing Kuviewer server URL with the same admin-token flow as the web app."
    },
    {
      "id": "local-sidecar",
      "description": "Future option: run the Go read-only API server as a local sidecar and point the desktop shell at localhost."
    }
  ],
  "buildPrerequisites": [
    {
      "id": "node",
      "requiredFor": ["macos", "windows"],
      "purpose": "Run the existing Vite frontend build before Tauri bundles the app."
    },
    {
      "id": "npm",
      "requiredFor": ["macos", "windows"],
      "purpose": "Install website and desktop package dependencies."
    },
    {
      "id": "rust",
      "requiredFor": ["macos", "windows"],
      "purpose": "Compile the Tauri shell."
    },
    {
      "id": "cargo",
      "requiredFor": ["macos", "windows"],
      "purpose": "Run the Rust build and package commands used by Tauri."
    },
    {
      "id": "xcode-command-line-tools",
      "requiredFor": ["macos"],
      "purpose": "Provide the macOS linker and native build tools for .dmg generation."
    },
    {
      "id": "windows-runner",
      "requiredFor": ["windows"],
      "purpose": "Build the Windows NSIS .exe on a Windows host or CI runner."
    }
  ],
  "icons": {
    "generationScript": "scripts/generate-desktop-icons.mjs",
    "sourceAssets": [
      {
        "id": "yaml-flow-source",
        "path": "website/public/images/brand/kuviewer-icon-yaml-flow.png",
        "size": "512x512",
        "transparent": true
      },
      {
        "id": "favicon-32",
        "path": "website/public/favicon-32x32.png",
        "size": "32x32",
        "transparent": true
      },
      {
        "id": "favicon-192",
        "path": "website/public/favicon-192x192.png",
        "size": "192x192",
        "transparent": true
      },
      {
        "id": "apple-touch-icon",
        "path": "website/public/apple-touch-icon.png",
        "size": "180x180",
        "transparent": true
      }
    ],
    "generatedAssets": [
      {
        "path": "desktop/src-tauri/icons/32x32.png",
        "size": "32x32",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128.png",
        "size": "128x128",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/128x128@2x.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.png",
        "size": "256x256",
        "format": "png"
      },
      {
        "path": "desktop/src-tauri/icons/icon.icns",
        "format": "icns",
        "platform": "macos"
      },
      {
        "path": "desktop/src-tauri/icons/icon.ico",
        "format": "ico",
        "platform": "windows"
      }
    ],
    "noCroppedCandidateImages": true
  },
  "signing": {
    "status": "ci-scaffolded",
    "noCertificatesInRepo": true,
    "noPrivateKeysInRepo": true,
    "workflowPath": ".github/workflows/desktop-package.yml",
    "manualOnly": true,
    "unsignedBuildDefault": true,
    "signedBuildRequiresSecrets": true,
    "macos": "Use an Apple Developer ID certificate and notarization credentials from the local keychain or CI secrets only.",
    "macosSecretNames": [
      "APPLE_CERTIFICATE_BASE64",
      "APPLE_CERTIFICATE_PASSWORD",
      "APPLE_SIGNING_IDENTITY",
      "APPLE_ID",
      "APPLE_PASSWORD",
      "APPLE_TEAM_ID"
    ],
    "windows": "Use a Windows code-signing certificate from a Windows runner or CI secrets only.",
    "windowsSecretNames": [
      "WINDOWS_CERTIFICATE_BASE64",
      "WINDOWS_CERTIFICATE_PASSWORD"
    ]
  },
  "security": {
    "readOnly": true,
    "noBrowserKubeCredentialEntry": true,
    "noSecretValues": true,
    "noKubeconfigPersistence": true,
    "noAdminTokenPersistence": true,
    "noOperationalActions": [
      "exec",
      "port-forward",
      "restart",
      "scale",
      "delete",
      "apply",
      "edit"
    ]
  },
  "phaseOrder": [
    "packaging-spec",
    "tauri-scaffold",
    "local-sidecar-evaluation",
    "macos-dmg-build",
    "windows-exe-build",
    "signing-and-release"
  ]
}
